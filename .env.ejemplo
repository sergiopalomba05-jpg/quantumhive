# QuantumHive — root

# Copiar a .env y llenar. NUNCA commitear el .env (está en .gitignore).

# === APIFY (Agente Investigador) ===
# Sacalo en https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# === GOOGLE AI STUDIO (Gemini 1.5 Pro) ===
# Sacala en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# === CLAUDE API (cerebro de los bots) ===
# Sacala en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# === TELEGRAM (cuando armemos el bot del cliente) ===
# Lo creás con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=
