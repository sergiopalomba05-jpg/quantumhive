rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsDocument() {
      return isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function createsOwnedDocument() {
      return isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /{collection}/{documentId} {
      allow create: if createsOwnedDocument();
      allow read, update, delete: if ownsDocument();
    }
  }
}
