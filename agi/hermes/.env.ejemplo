# Plantilla de variables de Hermes para la Fase 2 (catálogo).
# Copiá a %LOCALAPPDATA%\hermes\.env y completá. NUNCA commitees el .env real ni la service_role.

# ── Supabase — proyecto quantumhive-hermes (el catálogo) ──
SUPABASE_URL=https://gbngjsulhqcwgkqoxozy.supabase.co
SUPABASE_ANON_KEY=            # publishable/anon (SOLO lectura) — skill consultar-catalogo y la PWA
SUPABASE_SERVICE_ROLE_KEY=   # secret (ESCRIBE) — solo el skill catalogador. Sacala del panel de Supabase.

# ── Vertex AI (vía ADC de la VM de GCP, NO API key) ──
VERTEX_PROJECT_ID=project-aa5fb956-b08a-4e13-869
VERTEX_LOCATION=us-central1
GEMINI_CHAT_MODEL=gemini-2.5-flash    # opcional; modelo para el chat
GEMINI_INGESTA_MODEL=gemini-2.5-pro   # opcional; modelo para ver/escuchar reels
# NOTA: En VM de GCP, las credenciales son automáticas (ADC).
# En local, necesitás gcloud auth application-default login o un service-account JSON.
# Las Edge Functions de Supabase necesitan VERTEX_PROJECT_ID + VERTEX_LOCATION como secrets.

# ── Skill proyecto-graph (opcional) ──
QH_REPO=                     # ruta al repo (default: ~/Desktop/boveda obsidian)
