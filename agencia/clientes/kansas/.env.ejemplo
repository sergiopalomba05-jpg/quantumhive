# ============================================================================
# Carta Viva — variables de entorno (.env)
# ============================================================================
# Estas claves van SOLO acá (local, en .gitignore) o como SECRETS del Space /
# Render. NUNCA al repo público. Al repo sube solo este .env.ejemplo (vacío).
# Para clonar una carta: copiá la carpeta, editá CARTA_CONFIG + el menú en app.py,
# y seteá estas variables. La carta nueva = un Space nuevo con su propio .env.
# ============================================================================

# --- Identidad de la carta ---------------------------------------------------
RESTAURANT_ID=la-escaloneta          # id único por carta (aísla el caché de voz y el feedback)

# --- Cerebro (texto de la mesera) — ROUND-ROBIN + failover -------------------
# Cada request ARRANCA en el siguiente carril (reparte la carga para no quemar el límite por minuto
# de una sola key) y, si ese falla, cae por el resto. Si BRAIN_CHAIN está vacío, la cadena se arma
# SOLA con las keys que pongas (orden base: groq → gemini[todas sus keys] → openrouter).
GROQ_API_KEY=                        # Groq (gratis, rápido) — console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
# Gemini admite VARIAS keys gratis para repartir el cupo por minuto (cada una = un carril).
# Poné las que tengas; el código rota entre todas. GEMINI_API_KEY o GEMINI_KEY_1..8 (cualquiera sirve).
GEMINI_API_KEY=                      # Google AI Studio (1ª key)
GEMINI_KEY_1=                        # 2ª key gratis (otra cuenta) — opcional
GEMINI_KEY_2=                        # 3ª key gratis — opcional (y así hasta GEMINI_KEY_8)
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=                  # OpenRouter (gratis con modelos :free)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Orden manual (opcional). Vacío = automático. Ej: "groq:llama-3.3-70b-versatile,gemini:gemini-2.5-flash"
BRAIN_CHAIN=
MAX_HISTORY_TURNS=                   # opcional: cuántos turnos de historial mandar
# HF_TOKEN: lo usa el Space de HuggingFace para sí mismo. La app NO lo usa como cerebro (la inferencia
# gratuita de HF para chat es inestable); con Groq + Gemini(xN) + OpenRouter sobra para la beta.

# --- Voz (TTS) — rotación con failover entre proveedores ---------------------
# Misma idea que el cerebro: se prueba el proveedor PRINCIPAL; si tira cuota/error, rota al siguiente.
# Si TTS_CHAIN está vacío, la cadena se arma SOLA con las keys que pongas (orden: minimax → elevenlabs
# → cartesia). Para elegir el principal: poné TTS_CHAIN o simplemente cargá primero esa key.
# Ej: TTS_CHAIN=elevenlabs,minimax  → ElevenLabs principal, MiniMax de respaldo.
TTS_CHAIN=

# MiniMax T2A v2
MINIMAX_API_KEY=                     # clave sk-cp del plan de tokens/créditos
MINIMAX_VOICE=Spanish_UpsetGirl
MINIMAX_MODEL=speech-02-turbo        # turbo = menor latencia
MINIMAX_SPEED=1.2                    # 1.0 normal · 1.2 ágil · 1.3 ya se atropella
MINIMAX_VOL=5                        # volumen: 1.0 normal · subí si suena bajito (hasta 10)
MINIMAX_API_BASE=https://api.minimax.io

# ElevenLabs (voz premium) — elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE=EXAVITQu4vr4xnSDxMaL   # voice_id (esta es multilingüe; elegí la tuya en el panel)
ELEVENLABS_MODEL=eleven_multilingual_v2 # o eleven_turbo_v2_5 (más rápido/barato)
ELEVENLABS_API_BASE=https://api.elevenlabs.io

# Cartesia (Sonic) — cartesia.ai
CARTESIA_API_KEY=
CARTESIA_VOICE=                      # voice_id de Cartesia (OBLIGATORIO si la usás)
CARTESIA_MODEL=sonic-2
CARTESIA_API_BASE=https://api.cartesia.ai
CARTESIA_VERSION=2024-11-13          # header obligatorio de la API; actualizá si Cartesia lo cambia

# --- Caché de voz (Supabase Storage) -----------------------------------------
# Guarda cada frase ya hablada; si se repite, sale $0 e instantáneo. Tolerante:
# si Supabase no está, la voz se genera igual (sin caché).
TTS_CACHE=1
TTS_CACHE_BUCKET=tts-cache
# Caché de respuestas del flujo guiado (chips): la respuesta del LLM a una pregunta fija se guarda
# una vez y se reproduce $0. Solo aplica a chips (no a preguntas libres ni a acciones del carrito).
RESPUESTAS_CACHE=1
RESPUESTAS_TABLE=respuestas_cache
RESPUESTAS_VARIANTES=3               # variantes distintas por pregunta (la mesera rota, no repite igual)
PREWARM=                             # 1 = pre-genera saludo+botones al arrancar (gasta cuota; dejar vacío en demo)

# --- Supabase (caché de voz + feedback) --------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_FEEDBACK_TABLE=feedback

# --- Memoria de clientes (Plan Premium) --------------------------------------
# 1 = la mesera reconoce al comensal que vuelve (nombre, último pedido, visitas) por device_id.
# Vacío/0 = Plan Básico (no recuerda nada). Requiere Supabase configurado.
MEMORIA=
CLIENTES_TABLE=clientes

# --- Métricas de la demo (Plan Premium) --------------------------------------
# 1 = registra entradas, platos, chats y pedidos en la tabla `eventos` (Supabase).
METRICAS=
EVENTOS_TABLE=eventos

# --- Demo (portada con planes Básico/Premium) --------------------------------
DEMO_MODE=                           # 1 = muestra botones de demo en el splash

# --- Pedido interno al mozo (opcional, por Telegram) -------------------------
TELEGRAM_TOKEN=
ORDER_CHAT_ID=

# --- Otros opcionales --------------------------------------------------------
GEMINI_MAX_RETRIES=
MESERA_BUSY_MSG=
