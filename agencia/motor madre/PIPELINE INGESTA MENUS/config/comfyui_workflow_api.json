{
  "1": {
    "class_type": "Wav2VecModelLoader",
    "inputs": {
      "model": "wav2vec2-chinese-base_fp16.safetensors",
      "base_precision": "fp32",
      "load_device": "offload_device"
    }
  },
  "2": {
    "class_type": "MultiTalkModelLoader",
    "inputs": {
      "model": "Wan2_1-InfiniteTalk_Single_Q4_K_M.gguf"
    }
  },
  "3": {
    "class_type": "LoadAudio",
    "inputs": {
      "audio": "test_audio.mp3"
    }
  },
  "4": {
    "class_type": "MultiTalkWav2VecEmbeds",
    "inputs": {
      "wav2vec_model": ["1", 0],
      "audio_1": ["3", 0],
      "normalize_loudness": true,
      "num_frames": 81,
      "fps": 25.0,
      "audio_scale": 1.0,
      "audio_cfg_scale": 1.0,
      "multi_audio_type": "para"
    }
  },
  "5": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "wan2.1-i2v-14b-480p-Q4_K_M.gguf",
      "base_precision": "fp16",
      "quantization": "disabled",
      "load_device": "offload_device",
      "attention_mode": "sdpa",
      "multitalk_model": ["2", 0]
    }
  },
  "6": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "Wan2_1_VAE_bf16.safetensors",
      "precision": "fp16"
    }
  },
  "7": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "umt5-xxl-enc-fp8_e4m3fn.safetensors",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "disabled"
    }
  },
  "8": {
    "class_type": "LoadWanVideoClipTextEncoder",
    "inputs": {
      "model_name": "clip_vision_h.safetensors",
      "precision": "fp16",
      "load_device": "offload_device"
    }
  },
  "9": {
    "class_type": "WanVideoTextEncode",
    "inputs": {
      "positive_prompt": "A woman speaking naturally, looking at the camera",
      "negative_prompt": "blurry, low quality, distorted",
      "t5": ["7", 0],
      "force_offload": true,
      "device": "cpu"
    }
  },
  "10": {
    "class_type": "WanVideoClipVisionEncode",
    "inputs": {
      "clip_vision": ["8", 0],
      "image_1": ["13", 0],
      "strength_1": 1.0,
      "strength_2": 1.0,
      "crop": "center",
      "combine_embeds": "average",
      "force_offload": true
    }
  },
  "11": {
    "class_type": "WanVideoImageToVideoMultiTalk",
    "inputs": {
      "vae": ["6", 0],
      "width": 768,
      "height": 432,
      "frame_window_size": 81,
      "motion_frame": 25,
      "force_offload": false,
      "colormatch": "disabled",
      "start_image": ["13", 0],
      "clip_embeds": ["10", 0],
      "mode": "infinitetalk"
    }
  },
  "12": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["5", 0],
      "image_embeds": ["11", 0],
      "steps": 8,
      "cfg": 6.0,
      "shift": 5.0,
      "seed": 42,
      "force_offload": true,
      "scheduler": "unipc",
      "riflex_freq_index": 0,
      "text_embeds": ["9", 0],
      "multitalk_embeds": ["4", 0]
    }
  },
  "13": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "avatar_test.png"
    }
  },
  "14": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["6", 0],
      "samples": ["12", 0],
      "enable_vae_tiling": true,
      "tile_x": 384,
      "tile_y": 384,
      "tile_stride_x": 192,
      "tile_stride_y": 192
    }
  },
  "15": {
    "class_type": "SaveVideo",
    "inputs": {
      "video": ["16", 0],
      "filename_prefix": "pipeline_connector_welcome",
      "format": "mp4",
      "codec": "h264"
    }
  },
  "16": {
    "class_type": "CreateVideo",
    "inputs": {
      "images": ["14", 0],
      "fps": 25,
      "audio": ["3", 0]
    }
  }
}
