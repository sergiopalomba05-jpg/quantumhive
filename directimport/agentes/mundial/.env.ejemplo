# Copiar a .env y llenar con las keys reales.
# NUNCA commitear el .env (esta en el .gitignore de esta carpeta y de la raiz).

# --- Script 1 (scrape_maps.py) ---
# Token de Apify. Sacalo en https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# --- Script 2 (procesar_leads.py) ---
# Solo si vas a clasificar dudosos con Gemini (flag --gemini).
# Sacala en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Solo si vas a volcar a Google Sheet (sin el flag --no-sheet).
# Path absoluto al JSON de la Service Account de GCP con permisos Sheets.
GCP_SA_JSON_PATH=

# ID del Google Sheet destino. Tomalo de la URL:
# https://docs.google.com/spreadsheets/d/<ESTO_ES_EL_ID>/edit
SHEET_ID=
